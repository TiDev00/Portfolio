# EditorConfig — https://editorconfig.org
# Prettier reads these settings and uses them as defaults before applying .prettierrc rules.
root = true

# ─── All files ───────────────────────────────────────────────────────────────
[*]
charset             = utf-8
end_of_line         = lf
indent_style        = space
indent_size         = 2
tab_width           = 2
max_line_length     = 100
trim_trailing_whitespace = true
insert_final_newline = true

# ─── Markdown ────────────────────────────────────────────────────────────────
# Keep trailing spaces
[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length          = off

# ─── YAML (GitHub Actions, configs) ─────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ─── JSON ────────────────────────────────────────────────────────────────────
[*.json]
indent_size = 2

# ─── Shell scripts ───────────────────────────────────────────────────────────
[*.sh]
end_of_line = lf

# ─── CSS / SCSS / SASS ───────────────────────────────────────────────────────
[*.{css,scss,sass,less}]
indent_size = 2

# ─── Lockfiles — do not touch ────────────────────────────────────────────────
[{pnpm-lock.yaml,package-lock.json,yarn.lock}]
insert_final_newline     = unset
trim_trailing_whitespace = unset
